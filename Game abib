<style>
body{
    margin:0;
    background:black;
    color:white;
    text-align:center;
    font-family:Arial;
}

canvas{
    display:block;
    margin:auto;
    border:3px solid red;
}

/* Tombol HP */
.controls{
    position:fixed;
    bottom:20px;
    width:100%;
}

button{
