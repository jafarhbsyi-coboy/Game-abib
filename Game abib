    if(!jumping){
        dy = -10;
        jumping = true;
    }
}

function tembak(){
    bullets.push({x:x+40, y:y+20});
}

// UPDATE
function update(){
    dy += gravity;
    y += dy;

    if(y > 200){
        y = 200;
        dy = 0;
        jumping = false;
    }

    bullets.forEach(b=> b.x += 6);
}

